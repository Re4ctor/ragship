{
  "name": "ragship",
  "version": "0.1.0",
  "description": "Ship a folder of Markdown into a local RAG app using Ollama.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ragship": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "docker-compose.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:app && npm run build:landing",
    "build:app": "tsc && cp src/ui.html src/landing.html dist/",
    "build:landing": "mkdir -p site/assets && cp src/landing.html site/index.html && cp assets/ragship-mascot.svg site/assets/",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "ingest": "tsx src/ingest.ts",
    "ask": "tsx src/ask.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:app"
  },
  "keywords": [
    "rag",
    "ollama",
    "markdown",
    "local-ai",
    "libsql"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@libsql/client": "^0.15.12",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "glob": "^13.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
