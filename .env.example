# Ragship example configuration
DOCS_DIR=./docs/markdown
PORT=3000

DATABASE_URL=file:./data/rag.db
DATABASE_AUTH_TOKEN=
DATABASE_BUSY_RETRIES=8

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2:1b
OLLAMA_NUM_CTX=2048
OLLAMA_TEMPERATURE=0.1
OLLAMA_EMBEDDING_CONCURRENCY=2
OLLAMA_EMBEDDING_MAX_CHARS=2500
OLLAMA_RETRIES=3
OLLAMA_RETRY_BASE_MS=500

CHUNK_MIN_CHARS=1000
CHUNK_MAX_CHARS=2400
CHUNK_OVERLAP_CHARS=350
RAG_TOP_K=4
